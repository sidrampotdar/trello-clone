# MongoDB. Match docker-compose.yml credentials.
MONGODB_URI=mongodb://kanban:kanban@localhost:27017/trello_clone?authSource=admin

# NextAuth / Auth.js v5
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# GitHub OAuth (optional). Create app at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Anthropic API (optional). AI breakdown falls back to heuristic if missing.
ANTHROPIC_API_KEY=
